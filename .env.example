AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Or, use a generic OpenAI-compatible LLM (Personalization Model Feature)
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

SDLC_USE_MOCK=false

# Application Environment (dev | staging | prod)
APP_ENV=dev

# Vault Integration
VAULT_ENABLED=false
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/data/sdlc

# ── Knowledge Base (KB) Configuration ─────────────────────────
# Skills KB: auto-loaded from the Skills/ folder in your workspace (no config needed)

# Agile / Project KB — option 1: local Markdown file path
# AGILE_KB_PATH=C:\path\to\your\project_plan.md

# Agile / Project KB — option 2: Confluence page (requires all three vars)
# CONFLUENCE_URL=https://your-org.atlassian.net/wiki
# CONFLUENCE_PAGE_ID=123456789
# CONFLUENCE_TOKEN=your-confluence-api-token
