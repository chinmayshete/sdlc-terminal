{
  "name": "nexus-sdlc",
  "displayName": "Nexus SDLC Assistant",
  "description": "AI-powered SDLC terminal assistant with security governance, DevOps automation, Git operations, and Agile project management — all from within VS Code.",
  "version": "0.1.0",
  "publisher": "nexus-sdlc",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "sdlc",
    "ai",
    "security",
    "devops",
    "git",
    "agile",
    "jira",
    "nexus"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "auxiliarybar": [
        {
          "id": "nexus-sidebar",
          "title": "Nexus SDLC",
          "icon": "media/nexus-icon.svg"
        }
      ]
    },
    "views": {
      "nexus-sidebar": [
        {
          "type": "webview",
          "id": "nexus.chatView",
          "name": "Nexus Chat",
          "icon": "media/nexus-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "nexus.openChat",
        "title": "Nexus: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "nexus.switchMode",
        "title": "Nexus: Switch Mode"
      },
      {
        "command": "nexus.runScan",
        "title": "Nexus: Run Security Scan"
      },
      {
        "command": "nexus.scanCurrentFile",
        "title": "Nexus: Scan Current File"
      },
      {
        "command": "nexus.showTickets",
        "title": "Nexus: Show Tickets"
      },
      {
        "command": "nexus.gitStatus",
        "title": "Nexus: Git Status"
      },
      {
        "command": "nexus.healthCheck",
        "title": "Nexus: Health Check"
      },
      {
        "command": "nexus.startServer",
        "title": "Nexus: Start API Server",
        "icon": {
          "light": "media/play-green.svg",
          "dark": "media/play-green.svg"
        }
      },
      {
        "command": "nexus.stopServer",
        "title": "Nexus: Stop API Server",
        "icon": {
          "light": "media/stop-red.svg",
          "dark": "media/stop-red.svg"
        }
      },
      {
        "command": "nexus.restartServer",
        "title": "Nexus: Restart API Server"
      }
    ],
    "keybindings": [
      {
        "command": "nexus.openChat",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      }
    ],
    "configuration": {
      "title": "Nexus SDLC",
      "properties": {
        "nexus.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:9500",
          "description": "URL of the Nexus API server"
        },
        "nexus.autoStartServer": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Nexus API server when the extension activates"
        },
        "nexus.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python interpreter for starting the server"
        },
        "nexus.serverPort": {
          "type": "number",
          "default": 9500,
          "description": "Port for the Nexus API server"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "nexus.startServer",
          "when": "view == nexus.chatView",
          "group": "navigation@1"
        },
        {
          "command": "nexus.stopServer",
          "when": "view == nexus.chatView",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "command": "nexus.scanCurrentFile",
          "group": "nexus",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sarif": "^2.1.7",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^8.56.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
